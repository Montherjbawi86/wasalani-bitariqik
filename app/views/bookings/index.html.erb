<!-- app/views/bookings/index.html.erb -->
<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-5">
    <div>
      <h1 class="text-primary fw-bold mb-2">حجوزاتي</h1>
      <p class="text-muted">استعرض جميع حجوزاتك وإدارتها</p>
    </div>
  </div>

  <% if @bookings.any? %>
    <div class="row" id="bookingsContainer">
      <% @bookings.each do |booking| %>
        <div class="col-xl-6 col-lg-6 col-md-12 mb-4">
          <div class="card h-100 shadow-sm booking-card">
            <div class="card-header bg-primary text-white">
              <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><%= booking.ride.from_city %> → <%= booking.ride.to_city %></h6>
                <span class="badge bg-<%= booking_status_badge(booking.status) %>">
                  <%= booking_status_text(booking.status) %>
                </span>
              </div>
            </div>

            <div class="card-body">
              <div class="booking-info mb-3">
                <div class="d-flex align-items-center mb-2">
                  <i class="fas fa-calendar-alt text-primary me-2"></i>
                  <span><%= booking.ride.departure_time.strftime("%Y/%m/%d") %></span>
                </div>
                <div class="d-flex align-items-center mb-2">
                  <i class="fas fa-clock text-primary me-2"></i>
                  <span><%= booking.ride.departure_time.strftime("%H:%M") %></span>
                </div>
                <div class="d-flex align-items-center mb-2">
                  <i class="fas fa-chair text-primary me-2"></i>
                  <span><strong><%= booking.seats %></strong> مقاعد</span>
                </div>
                <div class="d-flex align-items-center mb-2">
                  <i class="fas fa-money-bill-wave text-primary me-2"></i>
                  <span class="fw-bold text-success"><%= number_to_currency(booking.ride.price * booking.seats, unit: "ل.س", precision: 0) %></span>
                </div>
                <div class="d-flex align-items-center">
                  <i class="fas fa-user-tie text-primary me-2"></i>
                  <span>السائق: <%= booking.ride.driver.name %></span>
                </div>
              </div>

              <% if booking.notes.present? %>
                <div class="alert alert-light border mt-3">
                  <small class="text-muted">
                    <i class="fas fa-sticky-note me-1"></i>
                    ملاحظاتك: <%= booking.notes %>
                  </small>
                </div>
              <% end %>

              <% if booking.ride.notes.present? %>
                <div class="alert alert-info border mt-2">
                  <small>
                    <i class="fas fa-info-circle me-1"></i>
                    ملاحظات السائق: <%= truncate(booking.ride.notes, length: 100) %>
                  </small>
                </div>
              <% end %>
            </div>

            <div class="card-footer bg-white">
              <div class="d-grid gap-2">
                <% if current_user == booking.user && booking.pending? %>
                  <%= button_to booking_path(booking), method: :delete,
                        data: { confirm: 'هل أنت متأكد من إلغاء هذا الحجز؟' },
                        class: "btn btn-outline-danger btn-sm" do %>
                    <i class="fas fa-times me-1"></i>إلغاء الحجز
                  <% end %>
                <% end %>

                <% if current_user.driver? && current_user == booking.ride.driver %>
                  <% if booking.pending? %>
                    <%= button_to confirm_booking_path(booking), method: :post,
                          class: "btn btn-success btn-sm" do %>
                      <i class="fas fa-check me-1"></i>قبول الحجز
                    <% end %>
                    <%= button_to reject_booking_path(booking), method: :post,
                          class: "btn btn-outline-danger btn-sm" do %>
                      <i class="fas fa-times me-1"></i>رفض الحجز
                    <% end %>
                  <% end %>
                <% end %>

                <%= link_to ride_path(booking.ride), class: "btn btn-outline-primary btn-sm" do %>
                  <i class="fas fa-eye me-1"></i>عرض تفاصيل الرحلة
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-5">
      <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>
        عرض <%= @bookings.count %> حجز من أصل <%= current_user.bookings.count %> حجوزات
      </div>
    </div>
  <% else %>
    <div class="text-center py-5">
      <div class="empty-state">
        <i class="fas fa-ticket-alt fa-4x text-muted mb-4"></i>
        <h3 class="text-muted mb-3">لا توجد حجوزات حالياً</h3>
        <p class="text-muted mb-4">لم تقم بحجز أي رحلات بعد</p>
        <%= link_to rides_path, class: "btn btn-primary btn-lg" do %>
          <i class="fas fa-route me-2"></i>استعرض الرحلات المتاحة
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<style>
.booking-card {
  transition: all 0.3s ease;
  border: none;
  border-radius: 15px;
}

.booking-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.12);
}

.booking-info {
  background: #f8f9fa;
  padding: 15px;
  border-radius: 10px;
}

.empty-state {
  max-width: 400px;
  margin: 0 auto;
}

.card-header {
  border-radius: 15px 15px 0 0 !important;
}

.btn-sm {
  border-radius: 8px;
  padding: 0.5rem 1rem;
}

.badge {
  font-size: 0.8rem;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // يمكنك إضافة أي JavaScript مخصص للحجوزات هنا
});
</script>
